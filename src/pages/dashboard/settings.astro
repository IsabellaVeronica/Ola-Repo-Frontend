---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Dashboard/Header.astro";
import Sidebar from "../../components/Dashboard/Sidebar.astro";
import Footer from "../../components/Dashboard/Footer.astro";
import { SettingsManager } from "../../components/Dashboard/Settings/SettingsManager";
import { AuthGuard } from "../../components/Dashboard/AuthGuard";

// Protect route (check for token)
const token = Astro.cookies.get("token")?.value;
if (!token) {
  return Astro.redirect("/login");
}
---

<Layout title="Configuración de Cuenta | Tu Tienda">
  <div class="flex flex-col min-h-screen bg-background bg-[url('https://www.transparenttextures.com/patterns/stardust.png')]">
    <Header />
    <div class="flex flex-1">
      <Sidebar />
      <main class="flex-1 p-6 md:p-8 overflow-y-auto">
        <AuthGuard client:load allowedRoles={['admin', 'manager']} panelName="Configuración">
          <SettingsManager client:only="react" />
        </AuthGuard>
      </main>
    </div>
    <Footer />
  </div>
</Layout>
