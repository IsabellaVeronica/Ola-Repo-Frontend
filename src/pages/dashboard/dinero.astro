---
import Layout from "../../layouts/Layout.astro";
import Sidebar from "@/components/Dashboard/Sidebar.astro";
import Header from "@/components/Dashboard/Header.astro";
import { MoneyManager } from "@/components/Dashboard/Money/MoneyManager";
import { AuthGuard } from "@/components/Dashboard/AuthGuard";
---

<Layout title="Dinero & Finanzas | Panel de Control">
  <AuthGuard client:load allowedRoles={['admin', 'manager']} panelName="Dinero & Finanzas">
    <div class="min-h-screen bg-background flex flex-col">
      <Header />
      <div class="flex flex-1">
        <Sidebar />
        <main class="flex-1 p-4 md:p-8 overflow-x-hidden">
          <MoneyManager client:load />
        </main>
      </div>
    </div>
  </AuthGuard>
</Layout>
