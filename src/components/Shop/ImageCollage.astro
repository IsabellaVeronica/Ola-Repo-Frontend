---
---
<div class="absolute inset-0 z-0 overflow-hidden pointer-events-none select-none">
  <!-- Solid Dark Overlay for Text Readability: Focused on the left third -->
  <div class="absolute inset-0 bg-gradient-to-r from-black/80 via-black/40 to-transparent z-10"></div>
  
  <!-- Image Grid: Sharp and Original Quality -->
  <div class="grid grid-cols-2 md:grid-cols-4 gap-0 h-full w-full">
    <div class="relative h-full overflow-hidden">
      <img src="/collage/collage_5.jpg" alt="" class="absolute inset-0 w-full h-full object-cover object-center" loading="eager" />
    </div>
    <div class="relative h-full overflow-hidden">
      <img src="/collage/collage_2.jpg" alt="" class="absolute inset-0 w-full h-full object-cover" loading="eager" />
    </div>
    <div class="relative h-full overflow-hidden">
      <img src="/collage/collage_1.jpg" alt="" class="absolute inset-0 w-full h-full object-cover" loading="eager" />
    </div>
    <div class="relative h-full overflow-hidden">
      <img src="/collage/collage_4.jpg" alt="" class="absolute inset-0 w-full h-full object-cover" loading="eager" />
    </div>
  </div>
  
  <!-- Bottom Fade: More subtle transition -->
  <div class="absolute bottom-0 left-0 w-full h-16 bg-gradient-to-t from-background to-transparent z-20"></div>
</div>

<style>
  img {
    image-rendering: -webkit-optimize-contrast;
  }
</style>
