<header class="flex items-center justify-between p-4 bg-card/80 backdrop-blur-sm border-b border-border">
    <h1 class="text-2xl font-bold text-foreground">Panel Administrativo</h1>
    <button id="logout-button" class="px-4 py-2 bg-secondary text-secondary-foreground rounded-md hover:bg-secondary/80">Cerrar Sesión</button>
</header>

<script>
    const logoutButton = document.getElementById('logout-button');

    if (logoutButton) {
        logoutButton.addEventListener('click', () => {
            // Remove the auth token cookie
            document.cookie = 'token=; path=/; expires=Thu, 01 Jan 1970 00:00:00 GMT';
            // Remove user data from localStorage
            localStorage.removeItem('user');
            // Redirect to the login page
            window.location.href = '/login';
        });
    }
</script>